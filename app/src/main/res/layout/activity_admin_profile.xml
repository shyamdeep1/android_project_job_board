<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/figmaPageBg">

    <!-- Header Background -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="@color/figmaPrimaryBtn"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp">

        <!-- Header with back button -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="64dp">

            <!-- Back Button (gray circle) -->
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:background="@drawable/bg_circle_gray"
                android:scaleType="fitCenter"
                android:padding="8dp"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Admin Profile"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_centerInParent="true" />
        </RelativeLayout>
    </LinearLayout>

    <!-- Content Card -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="100dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_content_card"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="36dp"
            android:paddingEnd="28dp"
            android:paddingBottom="28dp">

            <!-- Admin Name -->
            <EditText
                android:id="@+id/etAdminName"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/bg_input_figma_active"
                android:hint="Admin Name"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:singleLine="true"
                android:text="Super Admin"
                android:textColor="@color/figmaInputText"
                android:textColorHint="@color/figmaInputHint"
                android:textSize="16sp" />

            <!-- Admin Email -->
            <EditText
                android:id="@+id/etAdminEmail"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_input_figma"
                android:hint="Admin Email"
                android:inputType="textEmailAddress"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:singleLine="true"
                android:text="admin@jobportal.com"
                android:textColor="@color/figmaInputText"
                android:textColorHint="@color/figmaInputHint"
                android:textSize="16sp" />

            <!-- Phone Number -->
            <EditText
                android:id="@+id/etAdminPhone"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_input_figma"
                android:hint="Phone Number"
                android:inputType="phone"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:singleLine="true"
                android:text="+1 555 100 200"
                android:textColor="@color/figmaInputText"
                android:textColorHint="@color/figmaInputHint"
                android:textSize="16sp" />

            <!-- Change Password -->
            <EditText
                android:id="@+id/etAdminPassword"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_input_figma"
                android:hint="Change Password"
                android:inputType="textPassword"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:singleLine="true"
                android:textColor="@color/figmaInputText"
                android:textColorHint="@color/figmaInputHint"
                android:textSize="16sp" />

            <!-- Security / Settings notes -->
            <EditText
                android:id="@+id/etAdminSettings"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_input_figma"
                android:gravity="top|start"
                android:hint="Security / Settings notes"
                android:inputType="textMultiLine"
                android:paddingStart="24dp"
                android:paddingTop="18dp"
                android:paddingEnd="24dp"
                android:paddingBottom="18dp"
                android:text="2FA enabled, alert threshold: medium"
                android:textColor="@color/figmaInputText"
                android:textColorHint="@color/figmaInputHint"
                android:textSize="15sp" />

            <!-- Save Settings Button -->
            <Button
                android:id="@+id/btnSaveAdminProfile"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_figma_btn"
                android:stateListAnimator="@null"
                android:text="SAVE SETTINGS"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Logout Button -->
            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_input_figma"
                android:text="LOGOUT"
                android:textColor="@color/figmaBodyText"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
