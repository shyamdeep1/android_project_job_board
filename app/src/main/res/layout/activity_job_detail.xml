<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- ===== HEADER ===== -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingStart="16dp"
        android:paddingEnd="20dp"
        android:background="@color/white">

        <!-- Back Button (gray circle) -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/bg_circle_gray"
            android:scaleType="fitCenter"
            android:padding="8dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:contentDescription="Back" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Details"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:layout_centerInParent="true" />

        <!-- Bookmark Button (top right) -->
        <ImageView
            android:id="@+id/btnBookmark"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_bookmark_outline"
            android:scaleType="fitCenter"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Bookmark" />

    </RelativeLayout>

    <!-- Header bottom border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/headerBorder" />

    <!-- ===== SCROLLABLE CONTENT ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <!-- ===== COMPANY + JOB TITLE ===== -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Left: Company name + Job title -->
                <LinearLayout
                    android:id="@+id/layoutJobTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/ivCompanyLogo">

                    <TextView
                        android:id="@+id/tvCompanyName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Highspeed Studios"
                        android:textSize="14sp"
                        android:textColor="@color/textMuted" />

                    <TextView
                        android:id="@+id/tvJobTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Senior Software Engineer"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:layout_marginTop="6dp"
                        android:lineSpacingMultiplier="1.2" />
                </LinearLayout>

                <!-- Right: Company Logo -->
                <ImageView
                    android:id="@+id/ivCompanyLogo"
                    android:layout_width="80dp"
                    android:layout_height="50dp"
                    android:src="@drawable/ic_company"
                    android:scaleType="fitEnd"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentTop="true"
                    android:contentDescription="Company logo" />

            </RelativeLayout>

            <!-- ===== TAG CHIPS (Fulltime, Remote Working, Hourly) ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Fulltime"
                    android:textSize="14sp"
                    android:textColor="@color/colorPrimary"
                    android:background="@drawable/bg_tag_chip"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Remote Working"
                    android:textSize="14sp"
                    android:textColor="@color/colorPrimary"
                    android:background="@drawable/bg_tag_chip"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Hourly"
                    android:textSize="14sp"
                    android:textColor="@color/colorPrimary"
                    android:background="@drawable/bg_tag_chip"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="24dp" />

            <!-- ===== SALARY INFO ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="24dp">

                <!-- Icon circle -->
                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_salary"
                    android:background="@drawable/bg_info_icon_circle"
                    android:scaleType="centerInside"
                    android:padding="14dp"
                    android:contentDescription="Salary" />

                <!-- Text -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Salary"
                        android:textSize="13sp"
                        android:textColor="@color/textMuted" />

                    <TextView
                        android:id="@+id/tvSalary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$500 - $1,000/monthly"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ===== LOCATION INFO ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp">

                <!-- Icon circle -->
                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_location_bag"
                    android:background="@drawable/bg_info_icon_circle"
                    android:scaleType="centerInside"
                    android:padding="14dp"
                    android:contentDescription="Location" />

                <!-- Text -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Location"
                        android:textSize="13sp"
                        android:textColor="@color/textMuted" />

                    <TextView
                        android:id="@+id/tvLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Medan, Indonesia"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="24dp" />

            <!-- ===== JOB DESCRIPTION ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Job Description"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:layout_marginTop="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
                android:textSize="15sp"
                android:textColor="@color/textSecondary"
                android:layout_marginTop="14dp"
                android:lineSpacingMultiplier="1.5" />

            <!-- Bullet point 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="18dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_check_circle"
                    android:contentDescription="Check" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sed ut perspiciatis unde omnis"
                    android:textSize="15sp"
                    android:textColor="@color/textSecondary"
                    android:layout_marginStart="14dp" />
            </LinearLayout>

            <!-- Bullet point 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="14dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_check_circle"
                    android:contentDescription="Check" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Doloremque laudantium"
                    android:textSize="15sp"
                    android:textColor="@color/textSecondary"
                    android:layout_marginStart="14dp" />
            </LinearLayout>

            <!-- Bullet point 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="14dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_check_circle"
                    android:contentDescription="Check" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ipsa quae ab illo inventore"
                    android:textSize="15sp"
                    android:textColor="@color/textSecondary"
                    android:layout_marginStart="14dp" />
            </LinearLayout>

            <!-- Bullet point 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="14dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_check_circle"
                    android:contentDescription="Check" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Architecto beatae vitae dicta"
                    android:textSize="15sp"
                    android:textColor="@color/textSecondary"
                    android:layout_marginStart="14dp" />
            </LinearLayout>

            <!-- Bullet point 5 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="14dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_check_circle"
                    android:contentDescription="Check" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sunt explicabo"
                    android:textSize="15sp"
                    android:textColor="@color/textSecondary"
                    android:layout_marginStart="14dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ===== BOTTOM BAR: Bookmark + Apply Job ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="20dp"
        android:background="@color/white"
        android:elevation="8dp">

        <!-- Bookmark circle button -->
        <ImageView
            android:id="@+id/btnBookmarkBottom"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_bookmark_outline"
            android:background="@drawable/bg_circle_gray"
            android:scaleType="centerInside"
            android:padding="14dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="Save job" />

        <!-- Apply Job button -->
        <TextView
            android:id="@+id/btnApplyJob"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="APPLY JOB"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:letterSpacing="0.1"
            android:gravity="center"
            android:background="@drawable/bg_btn_apply" />

    </LinearLayout>

</LinearLayout>
