<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/tvReportedJob"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Android Developer at Highspeed Studios"
        android:textColor="@color/figmaBodyText"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvReason"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Reason: Fake posting / spam content"
        android:textColor="@color/figmaSubtitle"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvReporter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Reported by: Henry Kanwil"
            android:textColor="@color/statusBadgeGrey"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/btnDismiss"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="Dismiss"
            android:textColor="@color/statusBadgeGrey"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnTakeDown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Take Down"
            android:textColor="@color/figmaPrimaryBtn"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:background="@color/headerBorderLight" />
</LinearLayout>
