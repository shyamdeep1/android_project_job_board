<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    tools:context=".MessagesDetailActivity">

    <!-- ========== HEADER ========== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white">

        <!-- Status bar spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="44dp" />

        <!-- Header row: back | name+avatar | options -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="64dp">

            <!-- Back button -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginStart="14dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                android:contentDescription="Back" 
                android:scaleType="fitCenter" 
                android:padding="8dp" />

            <!-- Name + avatar (center) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvContactName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Claudia Surr"
                    android:textColor="@color/figmaBodyText"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    android:layout_marginEnd="10dp" />

                <ImageView
                    android:id="@+id/imgContactAvatar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_jobseeker"
                    android:background="@drawable/bg_circle_gray"
                    android:scaleType="centerCrop"
                    android:padding="4dp"
                    android:contentDescription="Contact avatar" />
            </LinearLayout>

            <!-- Options icon -->
            <ImageButton
                android:id="@+id/btnOptions"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="14dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_more"
                android:tint="@color/figmaBodyText"
                android:contentDescription="Options" />
        </RelativeLayout>

        <!-- Bottom border -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/headerBorderLight" />
    </LinearLayout>

    <!-- ========== CHAT AREA ========== -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/chatScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/white"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/chatContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- Received message 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"
                android:gravity="start">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chat_received"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:maxWidth="270dp">

                    <TextView
                        android:id="@+id/tvMsg1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Do you have a time for interviews today?"
                        android:textColor="@color/chatReceivedText"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="4.30 AM"
                    android:textColor="@color/chatTimestamp"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

            <!-- Received message 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"
                android:gravity="start">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chat_received"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:maxWidth="270dp">

                    <TextView
                        android:id="@+id/tvMsg2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Okay, please meet me at karan Avenue at 5 pm"
                        android:textColor="@color/chatReceivedText"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="9:44 AM"
                    android:textColor="@color/chatTimestamp"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

            <!-- Sent message 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"
                android:gravity="end">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chat_sent"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:maxWidth="230dp">

                    <TextView
                        android:id="@+id/tvMsg3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Yes, I have."
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="9.30 AM"
                    android:textColor="@color/chatTimestamp"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

            <!-- Sent message 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"
                android:gravity="end">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chat_sent"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:maxWidth="230dp">

                    <TextView
                        android:id="@+id/tvMsg4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="shyam that sir, thankyou"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="9.30 AM"
                    android:textColor="@color/chatTimestamp"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ========== MESSAGE INPUT BAR ========== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="@color/white"
        android:elevation="4dp">

        <!-- Text input -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="62dp"
            android:layout_weight="1"
            android:background="@drawable/bg_message_input">

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Type message..."
                android:textColorHint="@color/msgInputHint"
                android:textColor="@color/figmaBodyText"
                android:textSize="16sp"
                android:fontFamily="sans-serif"
                android:paddingStart="20dp"
                android:paddingEnd="56dp"
                android:inputType="textMultiLine"
                android:gravity="center_vertical" />

            <!-- Send button (inside input, right side) -->
            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="10dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_pen"
                android:tint="@color/figmaPrimaryBtn"
                android:contentDescription="Send" />
        </FrameLayout>
    </LinearLayout>

    <!-- ========== BOTTOM NAVIGATION ========== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="71dp"
        android:orientation="horizontal"
        android:background="@color/white"
        android:elevation="8dp">

        <!-- Home -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_home"
                android:tint="@color/bottomNavInactive"
                android:contentDescription="Home" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="@color/bottomNavInactive"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Notifications -->
        <LinearLayout
            android:id="@+id/navNotifications"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_notification"
                android:tint="@color/bottomNavInactive"
                android:contentDescription="Notifications" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notifications"
                android:textColor="@color/bottomNavInactive"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Messages (ACTIVE) -->
        <LinearLayout
            android:id="@+id/navMessages"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_messages"
                android:tint="@color/figmaPrimaryBtn"
                android:contentDescription="Messages" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Messages"
                android:textColor="@color/figmaPrimaryBtn"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Account -->
        <LinearLayout
            android:id="@+id/navAccount"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_account"
                android:tint="@color/bottomNavInactive"
                android:contentDescription="Account" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Account"
                android:textColor="@color/bottomNavInactive"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
