<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/figmaPageBg"
    tools:context=".ApplyFormActivity">

    <!-- Dark purple header -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@color/figmaHeaderBg"
        android:orientation="vertical"
        android:paddingTop="40dp"
        android:paddingStart="28dp"
        android:paddingEnd="28dp">

        <!-- Company logo placeholder (circular) -->
        <ImageView
            android:id="@+id/imgCompanyLogo"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_company"
            android:background="@drawable/bg_circle_gray"
            android:padding="8dp"
            android:scaleType="centerCrop" />

        <!-- Company name -->
        <TextView
            android:id="@+id/tvCompanyName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Highspeed Studios"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:fontFamily="sans-serif"
            android:textStyle="normal" />

        <!-- Job title -->
        <TextView
            android:id="@+id/tvJobTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Senior Software Engineer"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- White content card overlapping header -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="190dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_content_card"
            android:orientation="vertical"
            android:minHeight="600dp">

            <!-- Title row: back button + "Apply Form" -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:background="@color/white">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="28dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Back"
                    android:src="@drawable/ic_back" 
                android:scaleType="fitCenter" 
                android:padding="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Apply Form"
                    android:textColor="@color/figmaHeaderBg"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Divider line -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/figmaPageBg" />

            <!-- Form fields -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="24dp"
                android:paddingBottom="32dp">

                <!-- Name input (pre-filled) -->
                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_input_figma"
                    android:hint="Full Name"
                    android:text="Henry Kanwil"
                    android:textColor="@color/figmaInputText"
                    android:textColorHint="@color/figmaInputHint"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:inputType="textPersonName"
                    android:singleLine="true" />

                <!-- Email input (active state with border) -->
                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input_figma_active"
                    android:hint="Email"
                    android:text="sjalu433@mail.com"
                    android:textColor="@color/figmaInputText"
                    android:textColorHint="@color/figmaInputHint"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:inputType="textEmailAddress"
                    android:singleLine="true" />

                <!-- Phone input -->
                <EditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input_figma"
                    android:hint="Phone number"
                    android:textColor="@color/figmaInputText"
                    android:textColorHint="@color/figmaInputHint"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:inputType="phone"
                    android:singleLine="true" />

                <!-- Resume upload button (dashed border) -->
                <LinearLayout
                    android:id="@+id/btnUploadResume"
                    android:layout_width="match_parent"
                    android:layout_height="69dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_upload_resume"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+ Upload Resume"
                        android:textColor="@color/figmaUploadText"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- Resume status -->
                <TextView
                    android:id="@+id/tvResumeStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text=""
                    android:textColor="@color/colorPrimary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"
                    android:paddingStart="4dp" />

                <!-- APPLY JOB button -->
                <Button
                    android:id="@+id/btnApplyJob"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_figma_btn"
                    android:text="APPLY JOB"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:stateListAnimator="@null" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</FrameLayout>
