<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pageBg">

    <!-- ===================== BOTTOM NAVIGATION (defined first for layout_above reference) ===================== -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_bottom_nav"
        android:layout_alignParentBottom="true"
        android:elevation="8dp">

        <!-- Home (Active) -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                android:tint="@color/colorPrimary"
                android:contentDescription="Home" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="10sp"
                android:textColor="@color/colorPrimary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Notification -->
        <LinearLayout
            android:id="@+id/navNotification"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_notification"
                android:tint="@color/textMuted"
                android:contentDescription="Notification" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notification"
                android:textSize="10sp"
                android:textColor="@color/textMuted"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Messages -->
        <LinearLayout
            android:id="@+id/navMessages"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_messages"
                android:tint="@color/textMuted"
                android:contentDescription="Messages" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Messages"
                android:textSize="10sp"
                android:textColor="@color/textMuted"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Account -->
        <LinearLayout
            android:id="@+id/navAccount"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_account"
                android:tint="@color/textMuted"
                android:contentDescription="Account" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Account"
                android:textColor="@color/textMuted"
                android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- ===================== SCROLLABLE MAIN CONTENT ===================== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNav"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== PURPLE HEADER ===== -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:background="@color/colorPrimary"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="20dp">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Good Morning"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:layout_centerVertical="true"
                    android:layout_marginTop="-20dp"
                    android:layout_alignParentStart="true" />

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Henry Kanwil"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_below="@id/tvGreeting"
                    android:layout_alignParentStart="true"
                    android:layout_marginTop="4dp" />

                <!-- Profile Picture -->
                <ImageView
                    android:id="@+id/ivProfile"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_jobseeker"
                    android:background="@drawable/bg_company_logo"
                    android:scaleType="centerCrop"
                    android:contentDescription="Profile"
                    android:padding="4dp" />

            </RelativeLayout>

            <!-- ===== CONTENT AREA ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/pageBg"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="24dp">

                <!-- Search Bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_search_input"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:elevation="4dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_search"
                        android:contentDescription="Search" />

                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Search job here..."
                        android:textColorHint="@color/textMuted"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:background="@android:color/transparent"
                        android:paddingStart="10dp"
                        android:singleLine="true"
                        android:inputType="text"
                        android:imeOptions="actionSearch" />
                </LinearLayout>

                <!-- ===== STATS CARDS ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp">

                    <!-- Jobs Applied -->
                    <RelativeLayout
                        android:id="@+id/cardJobsApplied"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_stat_purple"
                        android:padding="16dp"
                        android:layout_marginEnd="10dp">

                        <TextView
                            android:id="@+id/tvJobsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="29"
                            android:textColor="@color/white"
                            android:textSize="34sp"
                            android:textStyle="bold"
                            android:layout_alignParentStart="true"
                            android:layout_alignParentTop="true" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jobs Applied"
                            android:textColor="#DDFFFFFF"
                            android:textSize="12sp"
                            android:layout_alignParentStart="true"
                            android:layout_alignParentBottom="true" />
                    </RelativeLayout>

                    <!-- Interviews -->
                    <RelativeLayout
                        android:id="@+id/cardInterviews"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_stat_blue"
                        android:padding="16dp"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:id="@+id/tvInterviewsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3"
                            android:textColor="@color/white"
                            android:textSize="34sp"
                            android:textStyle="bold"
                            android:layout_alignParentStart="true"
                            android:layout_alignParentTop="true" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Interviews"
                            android:textColor="#DDFFFFFF"
                            android:textSize="12sp"
                            android:layout_alignParentStart="true"
                            android:layout_alignParentBottom="true" />
                    </RelativeLayout>
                </LinearLayout>

                <!-- ===== CATEGORIES ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Categories"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:layout_marginTop="24dp" />

                <!-- Categories Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <LinearLayout android:id="@+id/categoryFlash" android:layout_width="0dp" android:layout_height="62dp"
                        android:layout_weight="1" android:background="@drawable/bg_category_item"
                        android:gravity="center" android:layout_marginEnd="8dp">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@drawable/ic_flash" android:contentDescription="Flash" />
                    </LinearLayout>

                    <LinearLayout android:id="@+id/categoryDesign" android:layout_width="0dp" android:layout_height="62dp"
                        android:layout_weight="1" android:background="@drawable/bg_category_item"
                        android:gravity="center" android:layout_marginEnd="8dp">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@drawable/ic_pen" android:contentDescription="Design" />
                    </LinearLayout>

                    <LinearLayout android:id="@+id/categoryUiUx" android:layout_width="0dp" android:layout_height="62dp"
                        android:layout_weight="1" android:background="@drawable/bg_category_item"
                        android:gravity="center" android:layout_marginEnd="8dp">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@drawable/ic_frame" android:contentDescription="UI/UX" />
                    </LinearLayout>

                    <LinearLayout android:id="@+id/categoryTranslate" android:layout_width="0dp" android:layout_height="62dp"
                        android:layout_weight="1" android:background="@drawable/bg_category_item"
                        android:gravity="center">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@drawable/ic_translate" android:contentDescription="Translate" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Categories Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <LinearLayout android:id="@+id/categoryCode" android:layout_width="0dp" android:layout_height="62dp"
                        android:layout_weight="1" android:background="@drawable/bg_category_item"
                        android:gravity="center" android:layout_marginEnd="8dp">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@drawable/ic_code" android:contentDescription="Code" />
                    </LinearLayout>

                    <LinearLayout android:id="@+id/categoryDatabase" android:layout_width="0dp" android:layout_height="62dp"
                        android:layout_weight="1" android:background="@drawable/bg_category_item"
                        android:gravity="center" android:layout_marginEnd="8dp">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@drawable/ic_database" android:contentDescription="Database" />
                    </LinearLayout>

                    <LinearLayout android:id="@+id/categoryMechanical" android:layout_width="0dp" android:layout_height="62dp"
                        android:layout_weight="1" android:background="@drawable/bg_category_item"
                        android:gravity="center" android:layout_marginEnd="8dp">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@drawable/ic_wrench" android:contentDescription="Mechanical" />
                    </LinearLayout>

                    <LinearLayout android:id="@+id/categoryMore" android:layout_width="0dp" android:layout_height="62dp"
                        android:layout_weight="1" android:background="@drawable/bg_category_more"
                        android:gravity="center">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@drawable/ic_more" android:contentDescription="More" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ===== JOB LIST (dynamic) ===== -->
                <TextView
                    android:id="@+id/tvJobsHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Jobs for you"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:layout_marginTop="24dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvJobs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/tvJobsEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="No jobs available yet"
                    android:textColor="@color/textMuted"
                    android:visibility="gone" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</RelativeLayout>
